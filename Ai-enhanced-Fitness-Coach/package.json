{
  "name": "ai-fitness-coach-backend",
  "version": "1.0.0",
  "description": "AI-Enhanced Fitness Coach Backend API",
  "main": "backend/app/main.py",
  "scripts": {
    "start": "cd backend && python start_no_reload.py",
    "dev": "cd backend && python -m uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload",
    "install-deps": "cd backend && pip install -r requirements.txt",
    "init-db": "cd backend && python init_db_complete.py",
    "setup": "cd backend && pip install -r requirements.txt && python init_db_complete.py"
  },
  "dependencies": {},
  "devDependencies": {}
}