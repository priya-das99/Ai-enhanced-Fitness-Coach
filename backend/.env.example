# Environment Configuration
SECRET_KEY=your-secret-key-change-this-in-production
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.1

# Database (SQLite - will be created automatically)
DATABASE_PATH=mood_capture.db

# CORS Origins (CodeSandbox compatible)
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:8000,http://127.0.0.1:8000,https://*.codesandbox.io,https://*.csb.app