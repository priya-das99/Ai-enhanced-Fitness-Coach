{
  "setupTasks": [
    {
      "name": "Install Dependencies",
      "command": "cd backend && pip install -r requirements.txt"
    },
    {
      "name": "Initialize Complete Database",
      "command": "cd backend && python init_db_complete.py"
    }
  ],
  "tasks": {
    "start-backend": {
      "name": "Start Backend Server",
      "command": "cd backend && python -m uvicorn app.main:app --host 0.0.0.0 --port 8000",
      "runAtStart": true
    }
  }
}